# ───────────────────────────────────────────────────────────
# Patria Grande — Boletín militante
# Variables de entorno necesarias (todo gratuito)
# ───────────────────────────────────────────────────────────

# Supabase (self-hosted gratuito o plan free)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Gemini API (free tier generoso - ai.google.dev)
GEMINI_API_KEY=AIza...

# Firecrawl (plan free: 500 paginas/mes) - OPCIONAL, se usa como fallback
FIRECRAWL_API_KEY=fc-...

# Telegram Bot (crear con @BotFather, gratis)
TELEGRAM_BOT_TOKEN=123456:AAA...

# Chat ID personal de Facu (para resumenes personales de 07:00 y 13:00)
TELEGRAM_PERSONAL_CHAT_ID=123456789

# Chat ID del grupo se configura en digest_config (tabla), no aca
